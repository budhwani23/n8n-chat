{
  "manifest_version": 3,
  "name": "n8n Chat",
  "version": "1.0",
  "description": "Chatbot that builds n8n workflows using LLMs via LangChain.",
  "icons": {
    "128": "icons/icon.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://app.n8n.cloud/*",
    "http://localhost:5678/*",
    "https://n8n-b6nw.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.n8n.cloud/*",
        "http://localhost:5678/*",
        "https://n8n-b6nw.onrender.com/*"
      ],
      "js": ["content.js"]
    }
  ]
} 